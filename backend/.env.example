# Скопируйте в .env и задайте СВОИ значения (файл .env не коммитится!)
PORT=5000
DATABASE_URL="file:./dev.db"
NODE_ENV=development

# JWT: сгенерируйте длинную случайную строку, напр. openssl rand -base64 48
JWT_SECRET=

# Пароли учёток seed (мин. 12 символов; admin123 и подобные запрещены)
SEED_ADMIN_PASSWORD=
SEED_MECHANIC_PASSWORD=

# URL фронтенда для CORS (на деплое — ваш домен)
CORS_ORIGIN=http://localhost:5173

# Login rate-limit ВКЛЮЧЁН по умолчанию (10 / 15 мин).
# Для локального Playwright / многократных логинов:
DISABLE_LOGIN_RATE_LIMIT=true

# legacy (ещё понимается бэкендом): ENABLE_LOGIN_RATE_LIMIT=false

# CSRF (double-submit) ВКЛЮЧЁН по умолчанию для POST/PUT/PATCH/DELETE
# (кроме /api/auth/login и /api/auth/csrf). Аварийный bypass:
# DISABLE_CSRF=true
