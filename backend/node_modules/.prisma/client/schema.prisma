datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  role     String // 'admin', 'mechanic', 'guest'
}

model Bike {
  id          String   @id @default(uuid())
  brand       String
  model       String
  year        Int
  vin         String   @unique
  mileage     Int
  status      String // 'available', 'repair', 'sold'
  lastService DateTime
  notes       String?
}
